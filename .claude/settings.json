{
  "permissions": {
    "allow": [
      "mcp__wayfinder__discover",
      "mcp__wayfinder__describe",
      "mcp__wayfinder__wallets",
      "mcp__wayfinder__tokens",
      "mcp__wayfinder__balances",
      "mcp__wayfinder__quote_swap",
      "mcp__wayfinder__hyperliquid",
      "mcp__wayfinder__polymarket",
      "mcp__wayfinder__compile_contract",
      "mcp__wayfinder__contract_get_abi",
      "mcp__wayfinder__contract_call"
    ],
    "ask": [
      "mcp__wayfinder__execute",
      "mcp__wayfinder__run_script",
      "mcp__wayfinder__hyperliquid_place_market_order",
      "mcp__wayfinder__hyperliquid_place_limit_order",
      "mcp__wayfinder__hyperliquid_place_outcome_order",
      "mcp__wayfinder__hyperliquid_place_trigger_order",
      "mcp__wayfinder__hyperliquid_cancel_order",
      "mcp__wayfinder__hyperliquid_update_leverage",
      "mcp__wayfinder__hyperliquid_deposit",
      "mcp__wayfinder__hyperliquid_withdraw",
      "mcp__wayfinder__polymarket_execute",
      "mcp__wayfinder__run_strategy",
      "mcp__wayfinder__deploy_contract",
      "mcp__wayfinder__contract_execute"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "poetry run python \"$CLAUDE_PROJECT_DIR/.claude/hooks/wayfinder_session_start.py\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(Write|Edit|MultiEdit|write|edit|multiedit)(Tool|tool)?$",
        "hooks": [
          {
            "type": "command",
            "command": "poetry run python \"$CLAUDE_PROJECT_DIR/.claude/hooks/wayfinder_write_guard.py\""
          }
        ]
      },
      {
        "matcher": "mcp__wayfinder__execute",
        "hooks": [
          {
            "type": "command",
            "command": "poetry run python \"$CLAUDE_PROJECT_DIR/.claude/hooks/wayfinder_execute_review.py\""
          }
        ]
      },
      {
        "matcher": "mcp__wayfinder__run_script",
        "hooks": [
          {
            "type": "command",
            "command": "poetry run python \"$CLAUDE_PROJECT_DIR/.claude/hooks/wayfinder_run_script_review.py\""
          }
        ]
      },
      {
        "matcher": "mcp__wayfinder__hyperliquid_(place_market_order|place_limit_order|place_outcome_order|place_trigger_order|cancel_order|update_leverage|deposit|withdraw)",
        "hooks": [
          {
            "type": "command",
            "command": "poetry run python \"$CLAUDE_PROJECT_DIR/.claude/hooks/wayfinder_hyperliquid_review.py\""
          }
        ]
      },
      {
        "matcher": "mcp__wayfinder__polymarket_execute",
        "hooks": [
          {
            "type": "command",
            "command": "poetry run python \"$CLAUDE_PROJECT_DIR/.claude/hooks/wayfinder_polymarket_execute_review.py\""
          }
        ]
      },
      {
        "matcher": "mcp__wayfinder__run_strategy",
        "hooks": [
          {
            "type": "command",
            "command": "poetry run python \"$CLAUDE_PROJECT_DIR/.claude/hooks/wayfinder_strategy_review.py\""
          }
        ]
      },
      {
        "matcher": "mcp__wayfinder__deploy_contract",
        "hooks": [
          {
            "type": "command",
            "command": "poetry run python \"$CLAUDE_PROJECT_DIR/.claude/hooks/wayfinder_deploy_contract_review.py\""
          }
        ]
      },
      {
        "matcher": "mcp__wayfinder__contract_execute",
        "hooks": [
          {
            "type": "command",
            "command": "poetry run python \"$CLAUDE_PROJECT_DIR/.claude/hooks/wayfinder_contract_execute_review.py\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "poetry run python \"$CLAUDE_PROJECT_DIR/.claude/hooks/wayfinder_session_end.py\""
          }
        ]
      }
    ]
  }
}
